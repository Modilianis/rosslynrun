  `;
  panel.appendChild(statsBar);

  // Списък с маршрути
  var routeSection = document.createElement('div');
  routeSection.style.cssText = 'padding: 15px 20px;';
  routeSection.innerHTML = `
    <p style="margin: 0 0 12px 0; color: ${HOTEL_COLORS.primary}; font-size: 14px; font-weight: 700; border-bottom: 2px solid ${HOTEL_COLORS.primary}; padding-bottom: 8px;">
      🏃 Избери маршрут за бягане
    </p>
  `;
  
  var list = document.createElement('div');
  RUNNING_ROUTES.forEach(function(route) {
    var item = document.createElement('div');
    var borderColor = route.color;
    item.style.cssText = `
      padding: 14px 16px; 
      margin-bottom: 12px; 
      border-left: 5px solid ${borderColor}; 
      background: #f8f9fa; 
      border-radius: 10px; 
      cursor: pointer; 
      transition: all 0.3s;
    `;
    item.onmouseover = function() { 
