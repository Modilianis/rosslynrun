// Функция за получаване на времето
function getWeather() {
  const now = new Date();
  const hour = now.getHours();
  let weather = '';
  let temp = '';
  let icon = '';
  
  if (hour >= 6 && hour < 10) {
    weather = 'Слънчево утро';
    temp = '18°C';
    icon = '🌅';
  } else if (hour >= 10 && hour < 14) {
    weather = 'Слънчево';
    temp = '24°C';
    icon = '☀️';
  } else if (hour >= 14 && hour < 18) {
    weather = 'Частично облачно';
    temp = '26°C';
    icon = '⛅';
  } else if (hour >= 18 && hour < 21) {
    weather = 'Залез';
    temp = '21°C';
    icon = '🌅';
  } else if (hour >= 21 && hour < 24) {
    weather = 'Вечер';
    temp = '17°C';
    icon = '🌙';
  } else {
    weather = 'Нощ';
    temp = '14°C';
    icon = '🌙';
  }
  
  return { weather, temp, icon, hour };
}

// Функция за навигация стъпка по стъпка с реални ориентири
function getTurnByTurnDirections(routePoints, routeName) {
  const directions = [];
  const landmarks = {
    'Южен парк': ['Вход Южен парк', 'Алея в парка', 'Езерото'],
    'Витоша-NDK': ['НДК', 'Фонтана пред НДК', 'Бул. Витоша'],
    'Витоша - Борисова градина': ['Борисова градина', 'Езерото с лебедите', 'Алеята на признателността']
  };
  
  for (let i = 0; i < routePoints.length - 1; i++) {
    const current = routePoints[i];
    const next = routePoints[i + 1];
    const latDiff = next[0] - current[0];
    const lngDiff = next[1] - current[1];
    let direction = '';
    let distance = '';
    
    if (Math.abs(latDiff) > Math.abs(lngDiff)) {
      direction = latDiff > 0 ? 'на юг' : 'на север';
    } else {
      direction = lngDiff > 0 ? 'на изток' : 'на запад';
    }
    
    const distMeters = Math.round(Math.sqrt(latDiff * latDiff + lngDiff * lngDiff) * 111000);
    distance = distMeters < 1000 ? distMeters + ' м' : (distMeters / 1000).toFixed(1) + ' км';
    
    if (i === 0) {
      directions.push('🚀 Старт от хотела (бул. Витоша 106)');
    } else if (i === Math.floor(routePoints.length / 2)) {
      // Добавяме забележителност по средата на маршрута
      if (routeName.includes('Южен парк')) {
        directions.push('🌳 Среда на Южен парк - завой');
      } else if (routeName.includes('Витоша-NDK')) {
        directions.push('🏛️ Минаване покрай НДК');
      } else if (routeName.includes('Борисова градина')) {
        directions.push('🌲 Влизане в Борисова градина');
      }
    } else {
      directions.push(`➡️ Продължи ${direction} - ${distance}`);
    }
  }
  directions.push('🏁 Връщане в хотела (бул. Витоша 106)');
  return directions;
}

// Изчакай DOM да се зареди
